<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox is OFF: the app needs the Accessibility API and broad file access,
	     which are incompatible with the App Sandbox for a developer-distributed tool. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
